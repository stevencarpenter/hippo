{
  "uid": "hippo-bench-model-drilldown",
  "title": "Hippo Bench — Model Drilldown",
  "tags": [
    "hippo",
    "bench",
    "drilldown"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "model_id",
        "label": "Model ID",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(hippo_bench_latency_p95_ms{service_namespace=\"hippo-bench\"}, bench_model_id)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Per-Event Latency over Bench Window",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_event_latency_ms{service_namespace=\"hippo-bench\",bench_model_id=\"$model_id\"}",
          "legendFormat": "p50",
          "editorMode": "code"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_latency_p95_ms{service_namespace=\"hippo-bench\",bench_model_id=\"$model_id\"}",
          "legendFormat": "p95",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5000
              },
              {
                "color": "red",
                "value": 30000
              }
            ]
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "title": "System Metrics over Bench Window",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_cpu_percent{service_namespace=\"hippo-bench\",bench_model_id=\"$model_id\"}",
          "legendFormat": "CPU %",
          "editorMode": "code"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_load_avg_1m{service_namespace=\"hippo-bench\",bench_model_id=\"$model_id\"}",
          "legendFormat": "load avg 1m",
          "editorMode": "code"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_mem_free_bytes{service_namespace=\"hippo-bench\",bench_model_id=\"$model_id\"}",
          "legendFormat": "mem free",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "CPU %"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "mem free"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 3,
      "title": "Gate Pass Rates",
      "type": "bargauge",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_schema_validity_rate{service_namespace=\"hippo-bench\",bench_model_id=\"$model_id\"}",
          "legendFormat": "Schema Validity",
          "editorMode": "code"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_refusal_rate{service_namespace=\"hippo-bench\",bench_model_id=\"$model_id\"}",
          "legendFormat": "Non-Refusal Rate",
          "editorMode": "code"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_entity_sanity_rate{service_namespace=\"hippo-bench\",bench_model_id=\"$model_id\"}",
          "legendFormat": "Entity Sanity",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "green",
                "value": 0.9
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      }
    },
    {
      "id": 4,
      "title": "Downstream Proxy — Hit@K and MRR by Mode",
      "type": "bargauge",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_downstream_proxy_hit_at_1{service_namespace=\"hippo-bench\",bench_model_id=\"$model_id\"}",
          "legendFormat": "Hit@1 {{mode}}",
          "editorMode": "code"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_downstream_proxy_hit_at_5{service_namespace=\"hippo-bench\",bench_model_id=\"$model_id\"}",
          "legendFormat": "Hit@5 {{mode}}",
          "editorMode": "code"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_downstream_proxy_mrr{service_namespace=\"hippo-bench\",bench_model_id=\"$model_id\"}",
          "legendFormat": "MRR {{mode}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.3
              },
              {
                "color": "green",
                "value": 0.6
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      }
    }
  ]
}
