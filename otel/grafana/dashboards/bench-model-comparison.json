{
  "uid": "hippo-bench-model-comparison",
  "title": "Hippo Bench — Model Comparison",
  "tags": [
    "hippo",
    "bench",
    "comparison"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "run_id",
        "label": "Run ID",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(hippo_bench_latency_p95_ms{service_namespace=\"hippo-bench\"}, bench_run_id)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      },
      {
        "name": "model_a",
        "label": "Model A",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(hippo_bench_latency_p95_ms{service_namespace=\"hippo-bench\",bench_run_id=\"$run_id\"}, bench_model_id)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      },
      {
        "name": "model_b",
        "label": "Model B",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(hippo_bench_latency_p95_ms{service_namespace=\"hippo-bench\",bench_run_id=\"$run_id\"}, bench_model_id)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "P95 Latency Comparison",
      "type": "bargauge",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_latency_p95_ms{service_namespace=\"hippo-bench\",bench_run_id=\"$run_id\",bench_model_id=\"$model_a\"}",
          "legendFormat": "Model A: {{bench_model_id}}",
          "editorMode": "code"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_latency_p95_ms{service_namespace=\"hippo-bench\",bench_run_id=\"$run_id\",bench_model_id=\"$model_b\"}",
          "legendFormat": "Model B: {{bench_model_id}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5000
              },
              {
                "color": "red",
                "value": 30000
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      }
    },
    {
      "id": 2,
      "title": "Schema Validity Rate Comparison",
      "type": "bargauge",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_schema_validity_rate{service_namespace=\"hippo-bench\",bench_run_id=\"$run_id\",bench_model_id=\"$model_a\"}",
          "legendFormat": "Model A: {{bench_model_id}}",
          "editorMode": "code"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_schema_validity_rate{service_namespace=\"hippo-bench\",bench_run_id=\"$run_id\",bench_model_id=\"$model_b\"}",
          "legendFormat": "Model B: {{bench_model_id}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "green",
                "value": 0.9
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      }
    },
    {
      "id": 3,
      "title": "Downstream Hit@1 Comparison",
      "type": "bargauge",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_downstream_proxy_hit_at_1{service_namespace=\"hippo-bench\",bench_run_id=\"$run_id\",bench_model_id=\"$model_a\"}",
          "legendFormat": "Model A: {{bench_model_id}}",
          "editorMode": "code"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_downstream_proxy_hit_at_1{service_namespace=\"hippo-bench\",bench_run_id=\"$run_id\",bench_model_id=\"$model_b\"}",
          "legendFormat": "Model B: {{bench_model_id}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.3
              },
              {
                "color": "green",
                "value": 0.6
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      }
    },
    {
      "id": 4,
      "title": "System Load Peak Comparison",
      "type": "bargauge",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_load_avg_1m_peak{service_namespace=\"hippo-bench\",bench_run_id=\"$run_id\",bench_model_id=\"$model_a\"}",
          "legendFormat": "Model A: {{bench_model_id}}",
          "editorMode": "code"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hippo_bench_load_avg_1m_peak{service_namespace=\"hippo-bench\",bench_run_id=\"$run_id\",bench_model_id=\"$model_b\"}",
          "legendFormat": "Model B: {{bench_model_id}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 4.0
              },
              {
                "color": "red",
                "value": 8.0
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      }
    }
  ]
}
