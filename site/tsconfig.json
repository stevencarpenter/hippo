{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["astro/client", "node"]
  },
  "include": ["src/**/*", "integrations/**/*", "scripts/**/*", "tests/**/*", "*.mjs", "*.ts"],
  "exclude": ["dist", "node_modules", ".astro"]
}
