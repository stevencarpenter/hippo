---
export interface Props {
  size?: "full" | "reduced" | "inline";
  caption?: string;
  breathe?: boolean;
  decorative?: boolean;
  class?: string;
}
const {
  size = "full",
  caption,
  breathe = false,
  decorative = true,
  class: className = "",
} = Astro.props;
const px = size === "full" ? 200 : size === "reduced" ? 32 : 24;
const stroke = size === "inline" ? 1.4 : 1;
---
<figure aria-hidden={decorative ? "true" : undefined} class={`motif motif-marginalia ${breathe ? "breathe" : ""} ${className}`}>
  <svg
    viewBox="0 0 120 130"
    width={px}
    height={px}
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden={decorative ? "true" : undefined}
    role={decorative ? undefined : "img"}
    focusable="false"
  >
    {!decorative && <title>marginalia — quill ribbon and hatching</title>}
    <g fill="none" stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round">
      {/* Page edge: a single vertical rule at the left margin, with a few
          ornamental serifs at the top and bottom — the literal "margin" of
          the page where marginalia would be written. */}
      <path d="M30 18 L30 112"/>
      <path d="M26 18 L34 18 M26 112 L34 112" stroke-width={stroke * 0.8}/>

      {/* Pilcrow flourish — drop-cap-style P with a curling tail, the
          archetypal marginalia mark. */}
      <path d="M52 32 L52 78"/>
      <path d="M52 32 Q72 32, 72 46 Q72 60, 52 60"/>
      <path d="M64 32 L64 78"/>
      {/* Curling pen flourish coming off the bottom of the pilcrow. */}
      <path d="M64 78 Q64 92, 78 94 Q92 96, 92 84 Q92 76, 84 76 Q78 76, 78 82" stroke-width={stroke * 0.85}/>

      {/* Three short ornament marks running down the right side — typical
          drypoint-style marginal notations. */}
      <path d="M100 38 L106 36 M100 42 L104 41" stroke-width={stroke * 0.6}/>
      <path d="M100 60 L106 58 M100 64 L104 63" stroke-width={stroke * 0.6}/>
      <path d="M100 82 L106 80 M100 86 L104 85" stroke-width={stroke * 0.6}/>

      {/* Tiny ink dots — pen rests against the page. */}
      <circle cx="44" cy="100" r="0.9" fill="currentColor"/>
      <circle cx="48" cy="103" r="0.7" fill="currentColor"/>
    </g>
  </svg>
  {caption && size === "full" && (
    <figcaption class="fig-caption" aria-hidden="true">{caption}</figcaption>
  )}
</figure>

<style>
  .motif { display: inline-flex; flex-direction: column; align-items: center; color: var(--ink); }
  .motif svg { color: var(--ink); transform-origin: center; will-change: transform; }
  .motif.breathe svg { animation: motif-breathe 8s ease-in-out infinite; }
  @keyframes motif-breathe { 0%,100% { transform: scale(1); } 50% { transform: scale(1.03); } }
  @media (prefers-reduced-motion: reduce) { .motif.breathe svg { animation: none; } }
</style>
