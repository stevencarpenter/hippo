# .understandignore — patterns for files/dirs to exclude from analysis
# Syntax: same as .gitignore (globs, # comments, ! negation, trailing / for dirs)
#
# Built-in defaults (always excluded unless negated):
#   node_modules/, .git/, dist/, build/, obj/, target/, *.lock, *.min.js, etc.

# --- Scope: "Core: daemon + brain" (chosen 2026-05-22) ---
# Center the graph on hippo's capture -> enrich -> serve system.
# Exclude peripheral surfaces:
site/
hippo-gui/
docs/archive/

# --- Build / vendor artifacts (belt-and-suspenders over built-in defaults) ---
target/
brain/.venv/
.venv/
**/__pycache__/
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage

# --- Generated / data ---
brain/src/hippo_brain/_version.py
*.db
*.db-wal
*.db-shm

# --- Editor / tooling noise ---
.idea/
.claude/
.understand-anything/
.DS_Store
