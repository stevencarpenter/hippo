{
  "manifest_version": 2,
  "name": "Hippo Browser Capture",
  "version": "0.2.0",
  "description": "Captures browsing activity for Hippo knowledge base",
  "icons": {
    "16": "icons/hippo-16.png",
    "32": "icons/hippo-32.png",
    "48": "icons/hippo-48.png",
    "128": "icons/hippo-128.png"
  },
  "permissions": [
    "alarms",
    "nativeMessaging",
    "storage",
    "<all_urls>"
  ],
  "content_security_policy": "script-src 'self'; object-src 'self'",
  "background": {
    "scripts": ["dist/background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Hippo",
    "default_icon": {
      "16": "icons/hippo-16.png",
      "32": "icons/hippo-32.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "hippo-browser@local"
    }
  }
}
